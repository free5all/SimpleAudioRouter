<UserControl x:Class="SimpleAudioRouter.Controls.DeviceRoutePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <StackPanel>
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Out L" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{StaticResource MutedTextBrush}"/>
            <ProgressBar x:Name="OutLeftMeter" Grid.Column="1" Minimum="0" Maximum="100"/>
            <TextBlock Grid.Column="2" Text="Out R" VerticalAlignment="Center" Margin="16,0,8,0"
                       Foreground="{StaticResource MutedTextBrush}"/>
            <ProgressBar x:Name="OutRightMeter" Grid.Column="3" Minimum="0" Maximum="100"/>
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="44"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding InputLabelLeft, ElementName=Root}"
                       VerticalAlignment="Center"/>
            <Slider x:Name="ToOutputLeftSlider" Grid.Row="0" Grid.Column="1"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="ToOutputLeftValue" Grid.Row="0" Grid.Column="2"
                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <Button x:Name="ResetLeftButton" Grid.Row="0" Grid.Column="3"
                    Style="{StaticResource GainResetButtonStyle}"
                    Content="↺"
                    ToolTip="Reset to 100%"
                    Margin="6,0,0,0"
                    Click="ResetLeftButton_Click"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding InputLabelRight, ElementName=Root}"
                       VerticalAlignment="Center"/>
            <Slider x:Name="ToOutputRightSlider" Grid.Row="1" Grid.Column="1"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="ToOutputRightValue" Grid.Row="1" Grid.Column="2"
                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <Button x:Name="ResetRightButton" Grid.Row="1" Grid.Column="3"
                    Style="{StaticResource GainResetButtonStyle}"
                    Content="↺"
                    ToolTip="Reset to 100%"
                    Margin="6,0,0,0"
                    Click="ResetRightButton_Click"/>
        </Grid>
    </StackPanel>
</UserControl>
