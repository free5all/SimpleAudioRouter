<Window x:Class="SimpleAudioRouter.UpdateNoticeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SimpleAudioRouter.Controls"
        Title="Update available"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        WindowStyle="None"
        Background="{DynamicResource BgBrush}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Background="{DynamicResource BgBrush}"
            MinWidth="340"
            MaxWidth="400">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <controls:TitleBar Grid.Row="0"
                               Title="Update available"
                               ShowMinimize="False"
                               CloseClick="TitleBar_CloseClick"/>

            <Border Grid.Row="1"
                    Style="{StaticResource ContentCardStyle}"
                    Margin="12">
                <StackPanel>
                    <TextBlock x:Name="MessageText"
                               TextWrapping="Wrap"
                               LineHeight="20"
                               Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Later"
                                MinWidth="80"
                                Margin="0,0,8,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="LaterButton_Click"/>
                        <Button Content="Download update"
                                MinWidth="120"
                                IsDefault="True"
                                Click="DownloadButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
