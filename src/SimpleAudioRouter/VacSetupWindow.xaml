<Window x:Class="SimpleAudioRouter.VacSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SimpleAudioRouter.Controls"
        Title="Set up virtual audio driver"
        Width="480"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        Background="{StaticResource BgBrush}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Background="{StaticResource BgBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <controls:TitleBar Grid.Row="0" Title="Virtual audio driver" ShowMinimize="False"/>

            <Border Grid.Row="1" Style="{StaticResource ContentCardStyle}">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,12"
                               Foreground="{StaticResource MutedTextBrush}"
                               LineHeight="20"
                               Text="SimpleAudioRouter needs a virtual audio driver. Download the official package, run the installer, then wait for detection."/>
                    <TextBlock x:Name="LinkText" Margin="0,0,0,12" Foreground="{StaticResource AccentBrush}"
                               Cursor="Hand" MouseLeftButtonUp="LinkText_MouseLeftButtonUp"
                               Text="https://vac.muzychenko.net/en/download.htm"/>
                    <TextBlock x:Name="StatusText" Text="Driver not installed." TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <ProgressBar x:Name="BusyBar" Height="8" IsIndeterminate="True" Visibility="Collapsed" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="DownloadButton" Content="Download" Width="90" Margin="0,0,8,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="DownloadButton_Click"/>
                        <Button x:Name="InstallButton" Content="Install" Width="90" Margin="0,0,8,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                IsEnabled="False" Click="InstallButton_Click"/>
                        <Button Content="Close" Width="90" Style="{StaticResource SecondaryButtonStyle}" Click="CloseButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
