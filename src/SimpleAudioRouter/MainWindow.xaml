<Window x:Class="SimpleAudioRouter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SimpleAudioRouter.Controls"
        Title="SimpleAudioRouter"
        Width="520"
        SizeToContent="Height"
        MinWidth="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanMinimize"
        Background="{DynamicResource BgBrush}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="6"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Background="{DynamicResource BgBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <controls:TitleBar Grid.Row="0" Title="SimpleAudioRouter">
                <controls:TitleBar.MenuContent>
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource TitleBarLinkStyle}" Content="Settings" Click="SettingsMenuItem_Click"/>
                        <Button Style="{StaticResource TitleBarLinkStyle}" Content="Driver" Click="SetupVacMenuItem_Click"/>
                        <Button Style="{StaticResource TitleBarLinkStyle}" Content="About" Click="AboutMenuItem_Click"/>
                    </StackPanel>
                </controls:TitleBar.MenuContent>
            </controls:TitleBar>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Margin="12,8,12,12">
                <StackPanel>
                    <GroupBox Header="Input" Style="{StaticResource CompactGroupBoxStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="L" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                            <ProgressBar x:Name="InputMeterLeft" Grid.Column="1" Minimum="0" Maximum="100"/>
                            <TextBlock Grid.Column="2" Text="R" VerticalAlignment="Center" Margin="16,0,8,0"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                            <ProgressBar x:Name="InputMeterRight" Grid.Column="3" Minimum="0" Maximum="100"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Left output device" Style="{StaticResource CompactGroupBoxStyle}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="LeftDeviceComboBox"
                                          Grid.Column="0"
                                          DisplayMemberPath="Name"
                                          SelectionChanged="DeviceComboBox_SelectionChanged"/>
                                <Button x:Name="TestLeftDeviceButton"
                                        Grid.Column="1"
                                        Content="Test"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="8,0,0,0"
                                        IsEnabled="False"
                                        Click="TestLeftDeviceButton_Click"/>
                            </Grid>
                            <controls:DeviceRoutePanel x:Name="LeftRoutePanel"
                                                       Margin="0,10,0,0"
                                                       InputLabelLeft="In L → Out L"
                                                       InputLabelRight="In L → Out R"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="RightDeviceGroup"
                              Header="Right output device"
                              Style="{StaticResource CompactGroupBoxStyle}"
                              Margin="0">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="RightDeviceComboBox"
                                          Grid.Column="0"
                                          DisplayMemberPath="Name"
                                          SelectionChanged="DeviceComboBox_SelectionChanged"/>
                                <Button x:Name="TestRightDeviceButton"
                                        Grid.Column="1"
                                        Content="Test"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="8,0,0,0"
                                        IsEnabled="False"
                                        Click="TestRightDeviceButton_Click"/>
                            </Grid>
                            <controls:DeviceRoutePanel x:Name="RightRoutePanel"
                                                       Margin="0,10,0,0"
                                                       InputLabelLeft="In R → Out L"
                                                       InputLabelRight="In R → Out R"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Style="{StaticResource StatusBarStripStyle}">
                <StackPanel x:Name="StatusBarPanel" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusIndicator"
                             Width="8"
                             Height="8"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center"
                             Fill="{StaticResource StatusIdleBrush}"/>
                    <TextBlock x:Name="StatusText"
                               Text="Idle"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
