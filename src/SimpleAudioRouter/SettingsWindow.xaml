<Window x:Class="SimpleAudioRouter.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SimpleAudioRouter.Controls"
        Title="Settings"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        Background="{DynamicResource BgBrush}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Background="{DynamicResource BgBrush}"
            MinWidth="340">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <controls:TitleBar Grid.Row="0" Title="Settings" ShowMinimize="False"/>

            <Border Grid.Row="1" Style="{StaticResource ContentCardStyle}">
                <StackPanel>
                    <CheckBox x:Name="StartWithWindowsCheckBox"
                              Content="Start with Windows"
                              Margin="0,0,0,10"/>
                    <CheckBox x:Name="StartMinimizedCheckBox"
                              Content="Start minimized to tray"
                              Margin="0,0,0,10"
                              ToolTip="On any launch, open in the tray instead of showing the window."/>
                    <CheckBox x:Name="MinimizeToTrayCheckBox"
                              Content="Minimize to tray when closing"
                              ToolTip="When enabled, closing the window keeps the app in the tray. When disabled, closing exits the app."/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True" Style="{StaticResource SecondaryButtonStyle}" Click="OkButton_Click"/>
                        <Button Content="Cancel" Width="80" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
