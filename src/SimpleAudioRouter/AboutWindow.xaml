<Window x:Class="SimpleAudioRouter.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SimpleAudioRouter.Controls"
        Title="About"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        Background="{StaticResource BgBrush}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Background="{StaticResource BgBrush}"
            MinWidth="340">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <controls:TitleBar Grid.Row="0" Title="About" ShowMinimize="False"/>

            <Border Grid.Row="1"
                    Style="{StaticResource ContentCardStyle}">
                <StackPanel>
                    <TextBlock Text="SimpleAudioRouter"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{StaticResource MutedTextBrush}"
                               LineHeight="20"
                               Text="Routes system audio through a virtual cable and sends left and right channels to separate output devices."/>
                    <Button Content="OK"
                            Width="80"
                            HorizontalAlignment="Right"
                            Margin="0,20,0,0"
                            IsDefault="True"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="OkButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
